# ====================================================================
# SOFTCONTABLE - Variables de Entorno
# ====================================================================

# ────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ────────────────────────────────────────────────────────────────────

# PostgreSQL Database URL (para producción en Railway)
# Formato: postgresql://user:password@host:port/database
# En Railway: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:password@localhost:5432/softcontable

# Usar PostgreSQL (true) o SQLite (false)
USE_POSTGRES=false

# SQLite Database Path (solo si USE_POSTGRES=false)
DATABASE_PATH=./database/pld_contable.db

# ────────────────────────────────────────────────────────────────────
# NODE ENVIRONMENT
# ────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=8080

# ────────────────────────────────────────────────────────────────────
# SECURITY
# ────────────────────────────────────────────────────────────────────

# JWT Secret (CAMBIAR EN PRODUCCIÓN)
JWT_SECRET=softcontable-super-secret-key-2026-CHANGE-THIS

# Encryption Key para credenciales SUNAT (32 caracteres)
ENCRYPTION_KEY=softcontable-2026-encryption-key

# ────────────────────────────────────────────────────────────────────
# FEATURES
# ────────────────────────────────────────────────────────────────────

# Habilitar rate limiting
ENABLE_RATE_LIMIT=true

# Cache TTL en milisegundos (30 minutos = 1800000)
CACHE_TTL=1800000

# ────────────────────────────────────────────────────────────────────
# STORAGE (para Railway con volumen persistente)
# ────────────────────────────────────────────────────────────────────

# Directorio base para almacenamiento
STORAGE_PATH=/app/storage

# ────────────────────────────────────────────────────────────────────
# RAILWAY SPECIFIC
# ────────────────────────────────────────────────────────────────────

# Railway proporciona estas automáticamente:
# RAILWAY_ENVIRONMENT
# RAILWAY_PROJECT_ID
# RAILWAY_SERVICE_ID

# ====================================================================
# INSTRUCCIONES
# ====================================================================

# LOCAL DEVELOPMENT:
# 1. Copia este archivo como .env
# 2. Ajusta los valores según tu entorno local
# 3. Usa USE_POSTGRES=false para desarrollo con SQLite

# RAILWAY PRODUCTION:
# 1. No subas .env a Git (está en .gitignore)
# 2. Configura las variables en Railway Dashboard → Variables
# 3. Usa DATABASE_URL=${{Postgres.DATABASE_URL}}
# 4. Usa USE_POSTGRES=true

